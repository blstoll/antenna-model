{
  "info": {
    "name": "Antenna Model Service API",
    "description": "Complete API collection for the Antenna Model Service - physics-based antenna gain modeling with calibrated correction surfaces.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health & Status",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Liveness probe - returns 200 OK if service is responsive"
          }
        },
        {
          "name": "Readiness Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/ready",
              "host": ["{{baseUrl}}"],
              "path": ["ready"]
            },
            "description": "Readiness probe - returns 200 OK when ready to accept requests, 503 during startup"
          }
        },
        {
          "name": "Service Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["status"]
            },
            "description": "Detailed service status including version, uptime, loaded antennas, and memory usage"
          }
        }
      ]
    },
    {
      "name": "Antenna Information",
      "item": [
        {
          "name": "List All Antennas",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/antennas",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "antennas"]
            },
            "description": "Get list of all available antennas with basic metadata"
          }
        },
        {
          "name": "Get Antenna Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/antennas/dsn_34m_uncalibrated",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "antennas", "dsn_34m_uncalibrated"]
            },
            "description": "Get comprehensive information about a specific antenna"
          }
        },
        {
          "name": "List Antenna Feeds",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/antennas/dsn_34m_uncalibrated/feeds",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "antennas", "dsn_34m_uncalibrated", "feeds"]
            },
            "description": "List all feeds available for a specific antenna"
          }
        },
        {
          "name": "Get Feed Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/antennas/dsn_34m_uncalibrated/feeds/x_band",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "antennas", "dsn_34m_uncalibrated", "feeds", "x_band"]
            },
            "description": "Get detailed information about a specific feed"
          }
        }
      ]
    },
    {
      "name": "Gain Computation",
      "item": [
        {
          "name": "Single Gain (ECEF)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"antenna_id\": \"dsn_34m_uncalibrated\",\n  \"feed_id\": \"x_band\",\n  \"vehicle_position\": {\n    \"x\": 6500000.0,\n    \"y\": 100000.0,\n    \"z\": 200000.0\n  },\n  \"vehicle_attitude\": [1.0, 0.0, 0.0, 0.0],\n  \"reflector_boresight\": {\n    \"x\": 6500010.0,\n    \"y\": 100000.0,\n    \"z\": 200000.0\n  },\n  \"feed_position\": {\n    \"x\": 6500005.0,\n    \"y\": 100000.0,\n    \"z\": 200000.0\n  },\n  \"emitter_position\": {\n    \"x\": 7000000.0,\n    \"y\": 500000.0,\n    \"z\": 1000000.0\n  },\n  \"frequency_mhz\": 8450.0,\n  \"include_reference\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/gain",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "gain"]
            },
            "description": "Compute antenna gain using ECEF coordinates and quaternion attitude"
          }
        },
        {
          "name": "Single Gain (Geodetic)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"antenna_id\": \"gs_3.7m_uncalibrated\",\n  \"feed_id\": \"x_band_feed\",\n  \"vehicle_position\": {\n    \"x\": -118.0,\n    \"y\": 34.0,\n    \"z\": 500.0\n  },\n  \"vehicle_attitude\": [1.0, 0.0, 0.0, 0.0],\n  \"reflector_boresight\": {\n    \"x\": -118.0,\n    \"y\": 34.0,\n    \"z\": 510.0\n  },\n  \"feed_position\": {\n    \"x\": -118.0,\n    \"y\": 34.0,\n    \"z\": 505.0\n  },\n  \"emitter_position\": {\n    \"x\": -100.0,\n    \"y\": 35.0,\n    \"z\": 500000.0\n  },\n  \"frequency_mhz\": 8200.0,\n  \"include_reference\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/gain",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "gain"]
            },
            "description": "Compute antenna gain using Geodetic coordinates and quaternion attitude"
          }
        },
        {
          "name": "Batch Gain Computation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"evaluations\": [\n    {\n      \"antenna_id\": \"dsn_34m_uncalibrated\",\n      \"feed_id\": \"x_band\",\n      \"vehicle_position\": {\"x\": 6500000.0, \"y\": 0.0, \"z\": 0.0},\n      \"vehicle_attitude\": [1.0, 0.0, 0.0, 0.0],\n      \"reflector_boresight\": {\"x\": 6500010.0, \"y\": 0.0, \"z\": 0.0},\n      \"feed_position\": {\"x\": 6500005.0, \"y\": 0.0, \"z\": 0.0},\n      \"emitter_position\": {\"x\": 7000000.0, \"y\": 0.0, \"z\": 500000.0},\n      \"frequency_mhz\": 8450.0,\n      \"include_reference\": false\n    },\n    {\n      \"antenna_id\": \"dsn_34m_uncalibrated\",\n      \"feed_id\": \"s_band\",\n      \"vehicle_position\": {\"x\": 6500000.0, \"y\": 0.0, \"z\": 0.0},\n      \"vehicle_attitude\": [1.0, 0.0, 0.0, 0.0],\n      \"reflector_boresight\": {\"x\": 6500010.0, \"y\": 0.0, \"z\": 0.0},\n      \"feed_position\": {\"x\": 6500005.0, \"y\": 0.0, \"z\": 0.0},\n      \"emitter_position\": {\"x\": 7000000.0, \"y\": 0.0, \"z\": 500000.0},\n      \"frequency_mhz\": 2250.0,\n      \"include_reference\": false\n    },\n    {\n      \"antenna_id\": \"gs_3.7m_uncalibrated\",\n      \"feed_id\": \"x_band_feed\",\n      \"vehicle_position\": {\"x\": 6500000.0, \"y\": 0.0, \"z\": 0.0},\n      \"vehicle_attitude\": [1.0, 0.0, 0.0, 0.0],\n      \"reflector_boresight\": {\"x\": 6500010.0, \"y\": 0.0, \"z\": 0.0},\n      \"feed_position\": {\"x\": 6500005.0, \"y\": 0.0, \"z\": 0.0},\n      \"emitter_position\": {\"x\": 7000000.0, \"y\": 0.0, \"z\": 500000.0},\n      \"frequency_mhz\": 7500.0,\n      \"include_reference\": false\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/gain/batch",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "gain", "batch"]
            },
            "description": "Process multiple gain computation requests in parallel (up to 1000 per batch)"
          }
        }
      ]
    },
    {
      "name": "Heatmap",
      "item": [
        {
          "name": "Generate Rectangular Heatmap",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"antenna_id\": \"test_simple\",\n  \"feed_id\": \"primary\",\n  \"vehicle_position\": {\n    \"x\": 6500000.0,\n    \"y\": 0.0,\n    \"z\": 0.0\n  },\n  \"reflector_boresight\": {\n    \"x\": 6500010.0,\n    \"y\": 0.0,\n    \"z\": 0.0\n  },\n  \"feed_position\": {\n    \"x\": 6500005.0,\n    \"y\": 0.0,\n    \"z\": 0.0\n  },\n  \"frequency_mhz\": 8250.0,\n  \"grid_config\": {\n    \"grid_type\": \"rectangular\",\n    \"azimuth_range_deg\": {\n      \"min\": 0.0,\n      \"max\": 10.0,\n      \"step\": 1.0\n    },\n    \"elevation_range_deg\": {\n      \"min\": 0.0,\n      \"max\": 10.0,\n      \"step\": 1.0\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/heatmap",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "heatmap"]
            },
            "description": "Generate a 2D loss heatmap across antenna field of view using rectangular grid"
          }
        }
      ]
    }
  ]
}

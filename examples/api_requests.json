          "z": 0.0
        },
        "reflector_boresight": {
          "x": 4510732.0,
          "y": 4510732.0,
          "z": 3488950.0
        },
        "feed_position": {
          "x": 4510731.5,
          "y": 4510731.5,
          "z": 3488870.0
        },
        "frequency_mhz": 8400.0,
        "grid_config": {
          "grid_type": "h3",
          "h3_resolution": 7,
          "center_azimuth_deg": 180.0,
          "center_elevation_deg": 45.0,
          "field_of_view_deg": 30.0
        }
      }
    },
    "heatmap_response_rectangular": {
      "description": "Heatmap response with rectangular grid data",
      "response": {
        "antenna_id": "antenna_1",

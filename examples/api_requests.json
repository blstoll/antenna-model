    "batch_response": {
      "description": "Batch gain computation response",
      "response": {
        "results": [
          {
            "antenna_id": "antenna_1",
            "feed_id": "x_band_feed",
            "gain_db": 41.2,
            "geometry": {
              "feed_offset_meters": {
                "x": 0.05,

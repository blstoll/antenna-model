    "status_response": {
      "description": "Service status response",
      "response": {
        "status": "ok",
        "version": "0.1.0",
        "uptime_seconds": 3600,
        "antenna_count": 2,
        "antenna_ids": ["antenna_1", "antenna_2"],
        "memory_bytes": 268435456
      }
    },
    "health_response": {
      "description": "Health check response",
      "response": {
        "status": "healthy"
      }
    },
    "antenna_list_response": {
      "description": "List of available antennas",
      "response": {
        "antennas": [
          {
            "id": "antenna_1",
            "name": "Deep Space Network 34m",
            "enabled": true,
            "feed_count": 3,
            "feed_ids": ["x_band_feed", "ka_band_feed", "s_band_feed"]
          },
          {
            "id": "antenna_2",
            "name": "Ground Station Array Element",
            "enabled": true,
            "feed_count": 1,
            "feed_ids": ["s_band_feed"]
          }
        ]
      }
    },
    "antenna_details_response": {
      "description": "Detailed antenna information",
      "response": {
        "id": "antenna_1",
        "name": "Deep Space Network 34m",
        "enabled": true,
        "feeds": [
          {
            "id": "x_band_feed",
            "position_offset": {
              "x": 0.0,

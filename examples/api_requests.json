    "heatmap_request_rectangular": {
      "description": "Heatmap generation request with rectangular grid",
      "request": {
        "antenna_id": "antenna_1",
        "feed_id": "x_band_feed",
        "vehicle_position": {
          "x": 4510731.123,
          "y": 4510731.456,
          "z": 3488865.789
        },
        "vehicle_attitude": {
          "w": 1.0,
          "x": 0.0,
          "y": 0.0,
          "z": 0.0
        },
        "reflector_boresight": {
          "x": 4510732.0,
          "y": 4510732.0,
          "z": 3488950.0
        },
        "feed_position": {
          "x": 4510731.5,
          "y": 4510731.5,
          "z": 3488870.0
        },
        "frequency_mhz": 8400.0,
        "pointing_frequency_mhz": 8450.0,
        "grid_config": {
          "grid_type": "rectangular",
          "azimuth_range_deg": {
            "min": 0.0,
            "max": 360.0,
            "step": 5.0
          },
          "elevation_range_deg": {
            "min": 0.0,
            "max": 90.0,
            "step": 2.0
          }
        }
      }
    },
    "heatmap_request_h3": {
      "description": "Heatmap generation request with H3 hexagonal grid",
      "request": {
        "antenna_id": "antenna_1",
        "feed_id": "x_band_feed",
        "vehicle_position": {
          "x": 4510731.123,
          "y": 4510731.456,
          "z": 3488865.789
        },
        "vehicle_attitude": {
          "w": 1.0,
          "x": 0.0,

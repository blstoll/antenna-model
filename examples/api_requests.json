    "error_response_antenna_not_found": {
      "description": "Error response for antenna not found",
      "response": {
        "error": "AntennaNotFound",
        "message": "Antenna 'invalid_antenna' not found"
      }
    },
    "error_response_feed_not_found": {
      "description": "Error response for feed not found",
      "response": {
        "error": "FeedNotFound",
        "message": "Feed 'invalid_feed' not found for antenna 'antenna_1'"
      }
    },
    "error_response_invalid_coordinate": {
      "description": "Error response for invalid coordinate",
      "response": {
        "error": "InvalidCoordinate",
        "message": "Coordinates exceed Earth radius (|pos| > 10000 km)",
        "field": "vehicle_position"
      }
    },
    "error_response_invalid_attitude": {
      "description": "Error response for invalid attitude",
      "response": {
        "error": "InvalidAttitude",
        "message": "Quaternion not normalized (|q| = 1.15)"
      }
    },
    "error_response_coordinate_transform": {
      "description": "Error response for coordinate transformation failure",
      "response": {
        "error": "CoordinateTransformError",
        "message": "Coordinate transformation failed",
        "details": "Gimbal lock at zenith (elevation = 90 degrees)"
      }
    }
